# Copy to each experiment folder and fill in values
# cp experiments/.env.example experiments/cpu-ta/.env
# cp experiments/.env.example experiments/gpu-ta/.env

# Must match the folder name (experiments/<EXPERIMENT>/)
EXPERIMENT=cpu-ta

# Alpha Vantage API key — premium recommended (no rate limits)
ALPHA_VANTAGE_API_KEY=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Git remote for pushing experiment results (optional)
# Format: https://<github_pat_token>@github.com/org/repo.git
GIT_REMOTE_URL=

# Claude model override (optional, defaults to claude-sonnet-4-6)
CLAUDE_MODEL=

# Live signals: days after signal entry to verify outcome (optional, default 7)
VERIFY_DAYS=7
